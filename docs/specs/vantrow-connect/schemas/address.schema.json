{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://connect.vantrow.example/schemas/v0/address.schema.json",
  "title": "Address",
  "description": "Postal address. Shared by Contact and Project.",
  "type": "object",
  "additionalProperties": false,
  "required": ["line1", "line2", "city", "region", "postal_code", "country"],
  "properties": {
    "line1": { "type": "string", "minLength": 1 },
    "line2": { "type": ["string", "null"] },
    "city": { "type": "string", "minLength": 1 },
    "region": {
      "type": "string",
      "description": "State / province / region code or name (e.g. \"OH\")."
    },
    "postal_code": { "type": "string" },
    "country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO 3166-1 alpha-2 country code, uppercase."
    }
  }
}
