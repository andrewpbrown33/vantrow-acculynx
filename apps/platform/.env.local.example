# Eaverow Platform — Supabase backend (optional)
#
# Copy this file to `.env.local` and fill in the three values to turn ON the
# real multi-tenant Supabase backend (email + password auth, self-serve signup,
# and per-org Row Level Security). See docs/runbooks/07-platform-supabase-backend.md.
#
# Leave these UNSET to run the zero-setup dev mode instead: a local file store
# (<repoRoot>/.data/platform.json) with a single seeded demo org and no login.
#
# Supabase mode is "on" only when BOTH the URL and the anon key below are present.

# Project URL, e.g. https://YOUR-PROJECT.supabase.co  (Supabase: Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose to the browser  (Supabase: Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SECRET service-role key — bypasses RLS; server-only, never expose to the browser.
# Used only for the public e-sign path and the signup → org bootstrap.
# (Supabase: Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Stripe Connect — real homeowner payments (optional)
#
# Leave UNSET to keep the demo payment stub (no real charge). Set the TEST
# secret key (sk_test_…) to turn on real Stripe Checkout in test mode. Hosted
# Checkout is redirect-based, so only the secret key is needed server-side.
#
# SECRET — server-only, never expose to the browser. (Stripe: Developers → API keys → Secret key)
STRIPE_SECRET_KEY=

# Webhook signing secret — verifies incoming Stripe webhooks. Locally, the
# Stripe CLI (`stripe listen`) prints one (whsec_…); in prod it comes from the
# webhook endpoint you create in the Stripe Dashboard. Set when we wire the webhook.
STRIPE_WEBHOOK_SECRET=
